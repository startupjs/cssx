{
  "name": "cssxjs",
  "version": "0.4.0-alpha.5",
  "description": "CSS-in-JS with actual CSS syntax",
  "type": "module",
  "main": "index.js",
  "bin": "./cli.js",
  "exports": {
    ".": "./index.js",
    "./check": "./check.js",
    "./babel": "./babel.cjs",
    "./babel/plugin-react-pug": "./babel/plugin-react-pug.cjs",
    "./babel/plugin-rn-stylename-inline": "./babel/plugin-rn-stylename-inline.cjs",
    "./babel/plugin-rn-stylename-to-style": "./babel/plugin-rn-stylename-to-style.cjs",
    "./metro-config": "./metro-config.cjs",
    "./metro-babel-transformer": "./metro-babel-transformer.cjs",
    "./loaders/cssToReactNativeLoader": "./loaders/cssToReactNativeLoader.cjs",
    "./loaders/stylusToCssLoader": "./loaders/stylusToCssLoader.cjs",
    "./runtime": {
      "react-native": "./runtime/react-native.js",
      "default": "./runtime/web.js"
    },
    "./runtime/teamplay": {
      "react-native": "./runtime/react-native-teamplay.js",
      "default": "./runtime/web-teamplay.js"
    },
    "./runtime/web": "./runtime/web.js",
    "./runtime/react-native": "./runtime/react-native.js",
    "./runtime/web-teamplay": "./runtime/web-teamplay.js",
    "./runtime/react-native-teamplay": "./runtime/react-native-teamplay.js",
    "./themes/tailwind": "./themes/tailwind.js",
    "./themes/shadcn": "./themes/shadcn.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "NODE_OPTIONS=\"${NODE_OPTIONS:-} -C cssx-ts\" node test/smoke.mjs"
  },
  "dependencies": {
    "@cssxjs/babel-plugin-rn-stylename-inline": "^0.4.0-alpha.5",
    "@cssxjs/babel-plugin-rn-stylename-to-style": "^0.4.0-alpha.2",
    "@cssxjs/bundler": "^0.4.0-alpha.5",
    "@cssxjs/css-to-rn": "^0.4.0-alpha.5",
    "@cssxjs/loaders": "^0.4.0-alpha.5",
    "@react-pug/babel-plugin-react-pug": "^0.1.18",
    "@react-pug/check-types": "^0.1.18",
    "babel-preset-cssxjs": "^0.4.0-alpha.5"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": "*",
    "react": "*"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": true
    }
  },
  "license": "MIT"
}
